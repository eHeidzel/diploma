{
  "version": 2,
  "buildCommand": "npm run build:all",
  "installCommand": "npm install --legacy-peer-deps",
  "functions": {
    "diploma/backend/dist/main.js": {
      "runtime": "nodejs18.x"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "diploma/backend/dist/main.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "diploma/frontend/index.html"
    }
  ]
}