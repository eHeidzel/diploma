{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install --legacy-peer-deps",
  "experimentalServices": {
    "frontend": {
      "root": "diploma/frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "root": "diploma/backend",
      "routePrefix": "/api"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api"
    },
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ]
}