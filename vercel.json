{
  "version": 2,
  "builds": [
    {
      "src": "diploma/backend/dist/main.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 10,
        "memory": 1024,
        "includeFiles": [
          "diploma/backend/dist/**",
          "diploma/backend/node_modules/**",
          "libs/shared/dist/**",
          "libs/shared/node_modules/**"
        ]
      }
    },
    {
      "src": "diploma/frontend/dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "diploma/backend/dist/main.js"
    },
    {
      "src": "/(.*)",
      "dest": "diploma/frontend/dist/index.html"
    }
  ]
}