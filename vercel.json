{
  "version": 2,
  "builds": [
    {
      "src": "diploma/frontend/**",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "diploma/frontend/dist"
      }
    },
    {
      "src": "diploma/backend/**",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "diploma/backend/src/main.ts"
    },
    {
      "src": "/(.*)",
      "dest": "diploma/frontend/index.html"
    }
  ]
}