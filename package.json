{
  "name": "diploma",
  "version": "1.0.0",
  "scripts": {
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "npm --prefix ./diploma/backend install --legacy-peer-deps && npm --prefix ./backend run build",
    "build:frontend": "npm --prefix ./diploma/frontend install --legacy-peer-deps && npm --prefix ./frontend run build",
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "node ./backend/dist/main.js",
    "start:frontend": "npm --prefix ./frontend run preview",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm --prefix ./backend run start:dev",
    "dev:frontend": "npm --prefix ./frontend run dev"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}